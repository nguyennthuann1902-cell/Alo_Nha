{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing role and linking information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["family", "elderly"] },
        "linkedUids": { "type": "array", "items": { "type": "string" } },
        "inviteCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "displayName"]
    },
    "HealthData": {
      "title": "HealthData",
      "description": "Health measurements for elderly users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "string" },
        "unit": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "value", "timestamp"]
    },
    "Medicine": {
      "title": "Medicine",
      "description": "Medicine schedule and intake tracking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "dose": { "type": "string" },
        "time": { "type": "string" },
        "note": { "type": "string" },
        "taken": { "type": "boolean" },
        "takenAt": { "type": "string", "format": "date-time" },
        "date": { "type": "string" }
      },
      "required": ["userId", "name", "time"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Log of activities and alerts.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "text", "timestamp"]
    },
    "LinkCode": {
      "title": "LinkCode",
      "description": "Short code used to link family members to elderly users.",
      "type": "object",
      "properties": {
        "elderUid": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["elderUid", "displayName"]
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "description": "A request to link accounts between two users.",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "toId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["fromId", "fromName", "toId", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection."
    },
    "/users/{userId}/health": {
      "schema": "HealthData",
      "description": "Subcollection for health measurements."
    },
    "/users/{userId}/medicines": {
      "schema": "Medicine",
      "description": "Subcollection for medicine schedules."
    },
    "/users/{userId}/activities": {
      "schema": "Activity",
      "description": "Subcollection for activity logs."
    },
    "/linkCodes/{code}": {
      "schema": "LinkCode",
      "description": "Global collection for active linking codes."
    },
    "/friendRequests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Global collection for account linking requests."
    }
  }
}
