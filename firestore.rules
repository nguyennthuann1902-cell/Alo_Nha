rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['email', 'displayName', 'userId']) &&
               data.email is string && data.email.size() <= 100 &&
               data.displayName is string && data.displayName.size() <= 100 &&
               data.userId == userId &&
               (data.get('role', null) == null || data.role in ['family', 'elderly']) &&
               (data.get('linkedUids', null) == null || data.linkedUids is list);
      }

      allow get: if isSignedIn();
      allow list: if false; // Prevention of user enumeration
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && isValidUser(incoming()) && (
          // Action: Update profile, roles or linkings
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'role', 'linkedUids', 'inviteCode', 'updatedAt'])
        )) ||
        (
          // Action: Allow child to link to elderly via verified code
          incoming().diff(existing()).affectedKeys().hasOnly(['linkedUids', '_lastLinkCode']) &&
          request.auth.uid in incoming().linkedUids &&
          exists(/databases/$(database)/documents/linkCodes/$(incoming()._lastLinkCode)) &&
          get(/databases/$(database)/documents/linkCodes/$(incoming()._lastLinkCode)).data.elderUid == userId
        )
      );
      
      // --- Subcollections ---
      match /requests/{requestId} {
        allow get: if isSignedIn() && (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);
        allow list: if isSignedIn() && (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);
        allow create: if isSignedIn() && request.auth.uid == incoming().fromUid;
        allow update: if isSignedIn() && request.auth.uid == resource.data.toUid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
        allow delete: if isSignedIn() && (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);
      }
      match /health/{id} {
        allow read: if isSignedIn() && (request.auth.uid == userId || request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.linkedUids);
        allow write: if isSignedIn() && request.auth.uid == userId; // Only elderly writes their own health
      }

      match /medicines/{id} {
        allow read: if isSignedIn() && (request.auth.uid == userId || request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.linkedUids);
        allow write: if isSignedIn() && (request.auth.uid == userId || request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.linkedUids);
      }

      match /activities/{id} {
        allow read: if isSignedIn() && (request.auth.uid == userId || request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.linkedUids);
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // --- LinkCodes ---
    match /linkCodes/{code} {
      function isValidLinkCode(data) {
        return data.keys().hasAll(['elderUid', 'displayName']) &&
               data.elderUid is string && isValidId(data.elderUid) &&
               data.displayName is string && data.displayName.size() <= 100;
      }

      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && isValidLinkCode(incoming()) && incoming().elderUid == request.auth.uid;
      allow delete: if isSignedIn() && (existing().elderUid == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/users/$(existing().elderUid)).data.linkedUids);
    }

    // --- FriendRequests ---
    match /friendRequests/{requestId} {
      function isValidFriendRequest(data) {
        return data.keys().hasAll(['fromId', 'fromName', 'toId', 'status', 'timestamp']) &&
               data.fromId == request.auth.uid &&
               data.status == 'pending' &&
               data.fromName is string && data.fromName.size() <= 100 &&
               data.toId is string && isValidId(data.toId);
      }

      allow read: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isSignedIn() && isValidFriendRequest(incoming());
      allow update: if isSignedIn() && resource.data.toId == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                    incoming().status in ['accepted', 'declined'];
      allow delete: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }
  }
}
